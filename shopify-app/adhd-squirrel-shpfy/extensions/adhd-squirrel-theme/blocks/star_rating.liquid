{% assign eyebrow = block.settings.eyebrow | default: 'ADHD SQUIRREL' %}
{% assign title = block.settings.title | default: 'The storefront is over there.' %}
{% assign body = block.settings.body | default: 'This Shopify surface handles the transaction side. Use the main storefront for the fuller ADHD Squirrel experience.' %}
{% assign primary_label = block.settings.primary_label | default: 'Open storefront' %}
{% assign primary_url = block.settings.primary_url | default: 'https://adhdsquirrelshop.com' %}
{% assign secondary_label = block.settings.secondary_label | default: 'Need help?' %}
{% assign secondary_url = block.settings.secondary_url | default: routes.contact_url %}

<div
  style="
    position: relative;
    overflow: hidden;
    padding: 1.5rem;
    border: 1px solid rgba(255, 90, 31, 0.24);
    border-radius: 20px;
    background:
      radial-gradient(circle at top right, rgba(255, 143, 31, 0.18), transparent 34%),
      linear-gradient(145deg, #121212 0%, #171717 52%, #0e0e0e 100%);
    color: #f5f2eb;
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.24);
  "
>
  <div
    style="
      position: absolute;
      inset: auto -18% -52% auto;
      width: 240px;
      height: 240px;
      border-radius: 999px;
      background: radial-gradient(circle, rgba(255, 90, 31, 0.18), rgba(255, 90, 31, 0));
      pointer-events: none;
    "
  ></div>

  <div style="position: relative; z-index: 1;">
    <div
      style="
        margin: 0 0 0.75rem;
        color: #ff8f6a;
        font-size: 0.76rem;
        font-weight: 800;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      "
    >
      {{ eyebrow }}
    </div>

    <h3
      style="
        margin: 0 0 0.75rem;
        font-size: clamp(1.4rem, 2.5vw, 1.95rem);
        line-height: 1.04;
        font-weight: 900;
        letter-spacing: -0.02em;
        text-transform: uppercase;
      "
    >
      {{ title }}
    </h3>

    <p
      style="
        max-width: 44rem;
        margin: 0 0 1.25rem;
        color: rgba(245, 242, 235, 0.78);
        font-size: 0.98rem;
        line-height: 1.55;
      "
    >
      {{ body }}
    </p>

    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
      <a
        href="{{ primary_url }}"
        style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-width: 180px;
          padding: 0.95rem 1.25rem;
          border-radius: 999px;
          background: linear-gradient(135deg, #ff5a1f 0%, #ff8a1f 100%);
          color: #ffffff;
          text-decoration: none;
          font-weight: 800;
          letter-spacing: 0.08em;
          text-transform: uppercase;
        "
      >
        {{ primary_label }}
      </a>

      <a
        href="{{ secondary_url }}"
        style="
          display: inline-flex;
          align-items: center;
          justify-content: center;
          min-width: 150px;
          padding: 0.95rem 1.25rem;
          border: 1px solid rgba(245, 242, 235, 0.18);
          border-radius: 999px;
          background: rgba(255, 255, 255, 0.02);
          color: #f5f2eb;
          text-decoration: none;
          font-weight: 700;
          letter-spacing: 0.06em;
          text-transform: uppercase;
        "
      >
        {{ secondary_label }}
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Storefront Bridge",
  "target": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "ADHD SQUIRREL" },
    { "type": "text", "id": "title", "label": "Title", "default": "The storefront is over there." },
    { "type": "textarea", "id": "body", "label": "Body", "default": "This Shopify surface handles the transaction side. Use the main storefront for the fuller ADHD Squirrel experience." },
    { "type": "text", "id": "primary_label", "label": "Primary button label", "default": "Open storefront" },
    { "type": "url", "id": "primary_url", "label": "Primary button URL" },
    { "type": "text", "id": "secondary_label", "label": "Secondary button label", "default": "Need help?" },
    { "type": "url", "id": "secondary_url", "label": "Secondary button URL" }
  ]
}
{% endschema %}

