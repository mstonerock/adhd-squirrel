# Shopify Storefront settings for live checkout handoff.
# Production Shopify store:
VITE_SHOPIFY_DOMAIN="snsjrm-sh.myshopify.com"

# Public Storefront API token from Shopify.
# Do not commit the real token.
VITE_SHOPIFY_STOREFRONT_ACCESS_TOKEN="your_storefront_access_token"

# JSON object mapping SKU -> Shopify ProductVariant GID.
# Source of truth is generated locally by:
#   npm run shopify:variant-map -- --shop snsjrm-sh.myshopify.com
# Which writes:
#   docs/shopify-variant-id-map.generated.json
# Copy only the "variantMap" object into this env var for Vercel/local env use.
VITE_SHOPIFY_VARIANT_ID_MAP='{"sonic-inferno-standard-tee__S":"gid://shopify/ProductVariant/48105462366400"}'

# Optional: explicit Shopify discount codes keyed by internal bundle id.
# These must exist in Shopify first. Without them, Shopify checkout will show full item prices.
VITE_SHOPIFY_BUNDLE_DISCOUNT_CODES='{"the-full-set":"FULLSET-7KQ2","diagnosis-pack":"DIAGPACK-4MZ8","complete-chaos-set":"CHAOSSET-9RXT"}'
